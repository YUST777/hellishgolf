# Server-only Supabase/Postgres connection.
# Prefer the pooled Supabase connection string in production.
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require

# Or use the split keys if you do not want one DATABASE_URL.
DB_HOST=aws-0-REGION.pooler.supabase.com
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres.PROJECT_REF
DB_PASSWORD=replace-with-your-db-password

# Set to disable only for a trusted local Postgres, never Supabase.
# DB_SSL=disable
