{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "peak-putt",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html",
        "height": "tall"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "permissions": {
    "redis": true,
    "reddit": {
      "enable": true,
      "asUser": ["SUBMIT_POST", "SUBMIT_COMMENT"]
    }
  },
  "settings": {
    "global": {
      "DATABASE_URL": {
        "type": "string",
        "label": "Supabase DATABASE_URL",
        "helpText": "Server-only pooled Supabase Postgres connection string.",
        "isSecret": true
      },
      "DB_HOST": {
        "type": "string",
        "label": "Supabase DB host",
        "helpText": "Use only if DATABASE_URL is not set."
      },
      "DB_PORT": {
        "type": "string",
        "label": "Supabase DB port",
        "helpText": "Use 6543 for the Supabase transaction pooler."
      },
      "DB_NAME": {
        "type": "string",
        "label": "Supabase DB name",
        "helpText": "Usually postgres."
      },
      "DB_USER": {
        "type": "string",
        "label": "Supabase DB user",
        "helpText": "Use only if DATABASE_URL is not set.",
        "isSecret": true
      },
      "DB_PASSWORD": {
        "type": "string",
        "label": "Supabase DB password",
        "helpText": "Use only if DATABASE_URL is not set.",
        "isSecret": true
      },
      "DB_SSL": {
        "type": "string",
        "label": "Database SSL mode",
        "helpText": "Leave empty for Supabase; set disable only for trusted local Postgres."
      }
    }
  },
  "menu": {
    "items": [
      {
        "label": "New Peak Putt hole",
        "description": "Create a new Peak Putt daily-style post",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      }
    ]
  },
  "scheduler": {
    "tasks": {
      "daily-hole": {
        "cron": "0 5 * * *",
        "endpoint": "/internal/scheduler/daily-hole"
      }
    }
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  }
}
